<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qcby.springboot_0525.mapper.EvaluationIndicatorMapper">

    <resultMap id="BaseResultMap" type="com.qcby.springboot_0525.entity.EvaluationIndicator">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="category" property="category"/>
        <result column="default_weight" property="defaultWeight"/>
        <result column="is_system" property="isSystem"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM evaluation_indicator WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM evaluation_indicator ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO evaluation_indicator (name, description, category, default_weight, is_system)
        VALUES (#{name}, #{description}, #{category}, #{defaultWeight}, #{isSystem})
    </insert>

    <update id="updateById">
        UPDATE evaluation_indicator
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="category != null">category = #{category},</if>
            <if test="defaultWeight != null">default_weight = #{defaultWeight},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM evaluation_indicator WHERE id = #{id}
    </delete>

</mapper>
