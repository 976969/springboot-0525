# 环境变量配置示例
# 复制此文件为 .env 并填写真实值
# 注意: .env 文件包含敏感信息,已在 .gitignore 中排除

# 数据库配置
DB_USERNAME=root
DB_PASSWORD=你的数据库密码

# 文件上传路径(可选,默认使用 ./uploads)
# Windows示例: UPLOAD_PATH=E:/upload/training/
# Linux示例: UPLOAD_PATH=/var/uploads/training/
UPLOAD_PATH=./uploads

# 大模型API密钥(阿里云百炼)
# 获取地址: https://bailian.console.aliyun.com/
LLM_API_KEY=你的API密钥
